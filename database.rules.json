{
  "rules": {
    ".read": false,
    ".write": false,

    "fa-users": {
      ".read": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
      "$userKey": {
        ".read": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
        ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)"
      }
    },

    "fa-ranking": {
      ".read": true,
      "$userKey": {
        ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)"
      }
    },

    "fa-progress": {
      ".read": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
      "$userKey": {
        ".read": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
        ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)"
      }
    },

    "fa-admins": {
      ".read": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
      "$userKey": {
        ".read": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
        ".write": "auth.token.email === 'tatianefdirene@previ.com.br' || auth.token.email === 'danielfrazao@previ.com.br'"
      }
    },

    "turmas": {
      ".read": true,
      "$turmaKey": {
        ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)"
      }
    },

    "turmas-interesse": {
      ".read": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
      "$turmaKey": {
        ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
        "$userKey": {
          ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)"
        }
      }
    },

    "turmas-interesse-log": {
      ".read": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
      "$turmaKey": {
        ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
        "$userKey": {
          ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)"
        }
      }
    },

    "turmas-config": {
      ".read": true,
      "$turmaKey": {
        ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)"
      }
    },

    "turmas-checkin": {
      ".read": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
      "$turmaKey": {
        ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
        "$data": {
          "$userKey": {
            ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)"
          }
        }
      }
    },

    "fa-seeds-hidden": {
      ".read": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
      "$key": {
        ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)"
      }
    },

    "fa-seeds-deleted": {
      ".read": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
      "$key": {
        ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)"
      }
    },

    "fa-holocron-hidden": {
      ".read": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
      "$key": {
        ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)"
      }
    },

    "fa-reset-signal": {
      "$userKey": {
        ".read": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)",
        ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)"
      }
    },

    "players": {
      ".read": true,
      "$key": {
        ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)"
      }
    },

    "holocron": {
      ".read": true,
      "$itemId": {
        ".write": "auth != null && auth.token.email.matches(/.*@previ\\.com\\.br/)"
      }
    }
  }
}
