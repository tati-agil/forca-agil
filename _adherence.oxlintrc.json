{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "forca-agil/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent",
      "--accent-2",
      "--blue",
      "--blue-deep",
      "--blue-glow",
      "--cyan",
      "--cyan-soft",
      "--ease",
      "--font-body",
      "--font-display",
      "--font-head",
      "--font-mono",
      "--gold",
      "--gold-soft",
      "--hero-haze",
      "--ink",
      "--ink-2",
      "--ink-3",
      "--line",
      "--line-strong",
      "--maxw",
      "--navy",
      "--navy-deep",
      "--panel",
      "--panel-2",
      "--red",
      "--red-deep",
      "--space-0",
      "--space-1",
      "--space-2",
      "--teal"
    ],
    "tokenKinds": {
      "--space-0": "spacing",
      "--space-1": "spacing",
      "--space-2": "spacing",
      "--panel": "color",
      "--panel-2": "color",
      "--line": "color",
      "--line-strong": "color",
      "--blue": "color",
      "--blue-deep": "color",
      "--blue-glow": "color",
      "--navy": "color",
      "--navy-deep": "color",
      "--gold": "color",
      "--gold-soft": "color",
      "--red": "color",
      "--red-deep": "color",
      "--cyan": "color",
      "--cyan-soft": "color",
      "--teal": "color",
      "--ink": "color",
      "--ink-2": "color",
      "--ink-3": "color",
      "--accent": "color",
      "--accent-2": "color",
      "--hero-haze": "color",
      "--maxw": "spacing",
      "--ease": "other",
      "--font-display": "font",
      "--font-head": "font",
      "--font-body": "font",
      "--font-mono": "font"
    },
    "fontFamilies": []
  }
}